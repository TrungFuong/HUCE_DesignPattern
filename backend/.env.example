app_name=OCOP Traceability API

# SQL Server relational database for users, farms, batches, shipments, risk rules.
# Replace username, password, host, database, and driver with your local setup.
sqlserver_url=mssql+aioodbc://sa:YourStrong!Passw0rd@localhost:1433/ocop_traceability?driver=ODBC+Driver+17+for+SQL+Server

# MongoDB stores IoT sensor logs.
mongodb_url=mongodb://localhost:27017

# Redis is used for queue/cache.
redis_url=redis://localhost:6379/0

# MQTT broker for sensor ingestion.
mqtt_broker_url=broker.hivemq.com
mqtt_topic=ocop/sensors/#

# Ganache / Ethereum smart contract config.
blockchain_rpc_url=http://127.0.0.1:7545
contract_address=
private_key=

# Base URL encoded into generated QR codes.
public_base_url=http://127.0.0.1:8000

jwt_secret_key=change-me
jwt_algorithm=HS256
access_token_expire_minutes=60
